# Example environment for the Portcullis demo stack.
#
# This file belongs to a deliberately vulnerable stack: the values below are
# exactly the kind of weak, guessable secrets that rule PC-008 flags. For a
# real deployment, generate long random values (e.g. `openssl rand -base64 32`)
# and never commit the resulting .env file to Git.

# DELIBERATE: a well-known default password (see the postgres service).
POSTGRES_PASSWORD=postgres

# DELIBERATE: "changeme" is among the first values any attacker or bot tries.
VAULTWARDEN_ADMIN_TOKEN=changeme
